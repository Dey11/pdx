# Local development without Docker.
# Requires local PostgreSQL and Redis already running on the host.

NODE_ENV=development

# Web
PORT=3000
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-a-local-secret
AUTH_SECRET=replace-with-a-local-secret
AUTH_TRUST_HOST=true

# Auth providers
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Email/password reset
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM="PDX <support@usepdx.tech>"

# Local database
DATABASE_URL=postgresql://user:password@localhost:5432/pdx_dev

# Local Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# Worker callback when running `bun run worker:dev` locally
BACKEND_URL=http://localhost:3000

# AI
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
AI_GENERATION_MODELS=deepseek:deepseek-v4-flash,deepseek:deepseek-chat,google:gemini-2.5-flash
AI_GENERATION_MAX_OUTPUT_TOKENS=8000

# Cloudflare R2
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ACCESS_KEY_ID=
CLOUDFLARE_SECRET_ACCESS_KEY=
CLOUDFLARE_TOKEN_VALUE=
BUCKET_NAME=test

# Puppeteer/Chrome for local PDF generation
PUPPETEER_EXECUTABLE_PATH=
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=false

# Payments
DODO_PAYMENTS_API_KEY=
WEBHOOK_SECRET=
STATIC_PAYMENT_LINK=
ADMIN_KEY=

# Analytics
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
