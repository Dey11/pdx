# Local development without Docker.
# Requires local PostgreSQL and Redis already running on the host.

NODE_ENV=development

# Web
PORT=3000
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-a-local-secret
AUTH_SECRET=replace-with-a-local-secret
AUTH_TRUST_HOST=true

# Auth providers
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Email/password reset
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM="NoteFormula <support@noteformula.com>"

# Local database
DATABASE_URL=postgresql://user:password@localhost:5432/noteformula_dev

# Local Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# Worker callback when running `bun run worker:dev` locally
BACKEND_URL=http://localhost:3000

# Shared secret authenticating worker -> web callbacks (/api/generation/*).
# Must be identical for the web app and the worker. Leave empty locally to
# skip verification (see src/lib/worker-auth.ts and worker/src/callback.ts).
WORKER_CALLBACK_SECRET=

# AI
# Read by both the web app and the worker.
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
# Ordered fallback chain, entries are `provider:model-id` (comma-separated).
AI_GENERATION_MODELS=deepseek:deepseek-v4-flash,deepseek:deepseek-chat,google:gemini-2.5-flash
AI_GENERATION_MAX_OUTPUT_TOKENS=8000

# Cloudflare R2
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ACCESS_KEY_ID=
CLOUDFLARE_SECRET_ACCESS_KEY=
BUCKET_NAME=test

# Puppeteer/Chrome for local PDF generation
PUPPETEER_EXECUTABLE_PATH=

# Payments
WEBHOOK_SECRET=
STATIC_PAYMENT_LINK=https://test.checkout.dodopayments.com/buy/PRODUCT_ID?quantity=1&redirect_url=http://localhost:3000/settings&email=USER_EMAIL&disableEmail=true
ADMIN_KEY=

# Analytics
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
