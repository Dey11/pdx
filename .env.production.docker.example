# Production Docker/Coolify env.
# Paste this as one combined env list in Coolify, then replace all placeholder values.
# If POSTGRES_PASSWORD contains URL-special characters, URL-encode it inside DATABASE_URL.

NODE_ENV=production
WEB_PORT=3000

# Compose-managed Postgres
POSTGRES_DB=pdx
POSTGRES_USER=pdx
POSTGRES_PASSWORD=replace-with-a-strong-db-password
DATABASE_URL=postgresql://pdx:replace-with-a-strong-db-password@postgres:5432/pdx?schema=public

# Compose-managed Redis
REDIS_PASSWORD=replace-with-a-strong-redis-password
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TLS=false

# Public web/auth URL
BETTER_AUTH_URL=https://your-coolify-domain.com
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_TRUST_HOST=true

# Auth providers
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Email/password reset
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM="PDX <support@your-domain.com>"

# Worker internal callback URL inside Docker Compose
BACKEND_URL=http://web:3000

# AI
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=

# Cloudflare R2
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ACCESS_KEY_ID=
CLOUDFLARE_SECRET_ACCESS_KEY=
CLOUDFLARE_TOKEN_VALUE=
BUCKET_NAME=prod

# Puppeteer/Chrome inside the worker image
PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

# Payments
DODO_PAYMENTS_API_KEY=
WEBHOOK_SECRET=
STATIC_PAYMENT_LINK=
ADMIN_KEY=

# Analytics
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
