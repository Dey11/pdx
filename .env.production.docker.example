# Production Docker/Coolify env.
# Paste this as one combined env list in Coolify, then replace all placeholder values.
# If POSTGRES_PASSWORD contains URL-special characters, URL-encode it inside DATABASE_URL.

NODE_ENV=production
WEB_PORT=3000

# Compose-managed Postgres
POSTGRES_DB=noteformula
POSTGRES_USER=noteformula
POSTGRES_PASSWORD=replace-with-a-strong-db-password
DATABASE_URL=postgresql://noteformula:replace-with-a-strong-db-password@postgres:5432/noteformula?schema=public

# Compose-managed Redis
REDIS_PASSWORD=replace-with-a-strong-redis-password
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TLS=false

# Public web/auth URL
BETTER_AUTH_URL=https://noteformula.com
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_TRUST_HOST=true

# Auth providers
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Email/password reset
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM="NoteFormula <support@noteformula.com>"

# Worker internal callback URL inside Docker Compose
BACKEND_URL=http://web:3000

# Shared secret authenticating worker -> web callbacks (/api/generation/*).
# Must be identical for the web and worker services (see src/lib/worker-auth.ts
# and worker/src/callback.ts). Required in production.
WORKER_CALLBACK_SECRET=replace-with-a-long-random-secret

# AI
# Read by both the web app and the worker.
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
# Ordered fallback chain, entries are `provider:model-id` (comma-separated).
AI_GENERATION_MODELS=deepseek:deepseek-v4-flash,deepseek:deepseek-chat,google:gemini-2.5-flash
AI_GENERATION_MAX_OUTPUT_TOKENS=8000

# Cloudflare R2
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ACCESS_KEY_ID=
CLOUDFLARE_SECRET_ACCESS_KEY=
BUCKET_NAME=prod

# Puppeteer/Chrome inside the worker image
PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

# Payments
WEBHOOK_SECRET=
STATIC_PAYMENT_LINK=https://checkout.dodopayments.com/buy/PRODUCT_ID?quantity=1&redirect_url=https://noteformula.com/settings&email=USER_EMAIL&disableEmail=true
ADMIN_KEY=

# Analytics
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
