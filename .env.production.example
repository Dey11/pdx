# Production without Docker.
# Use this when the web server and worker are run directly on a host/VM.

NODE_ENV=production

# Web
PORT=3000
BETTER_AUTH_URL=https://your-domain.com
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_TRUST_HOST=true

# Auth providers
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Email/password reset
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM="PDX <support@your-domain.com>"

# Managed database
DATABASE_URL=postgresql://user:password@host:5432/database?schema=public

# Managed Redis
REDIS_HOST=redis-host
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# Worker callback for a non-Docker production worker
BACKEND_URL=https://your-domain.com

# AI
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=

# Cloudflare R2
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ACCESS_KEY_ID=
CLOUDFLARE_SECRET_ACCESS_KEY=
CLOUDFLARE_TOKEN_VALUE=
BUCKET_NAME=prod

# Puppeteer/Chrome for production PDF generation
PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

# Payments
DODO_PAYMENTS_API_KEY=
WEBHOOK_SECRET=
STATIC_PAYMENT_LINK=
ADMIN_KEY=

# Analytics
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
