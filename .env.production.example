# Production without Docker.
# Use this when the web server and worker are run directly on a host/VM.

NODE_ENV=production

# Web
PORT=3000
BETTER_AUTH_URL=https://noteformula.com
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_TRUST_HOST=true

# Auth providers
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Email/password reset
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM="NoteFormula <support@noteformula.com>"

# Managed database
DATABASE_URL=postgresql://USER:PASSWORD@YOUR-NEON-HOST/neondb?sslmode=require

# Managed Redis
REDIS_HOST=redis-host
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# Worker callback for a non-Docker production worker
BACKEND_URL=https://noteformula.com

# Shared secret authenticating worker -> web callbacks (/api/generation/*).
# Must be identical for the web app and the worker (see src/lib/worker-auth.ts
# and worker/src/callback.ts). Required in production.
WORKER_CALLBACK_SECRET=replace-with-a-long-random-secret

# AI
# Read by both the web app and the worker.
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
# Ordered fallback chain, entries are `provider:model-id` (comma-separated).
AI_GENERATION_MODELS=deepseek:deepseek-v4-flash,deepseek:deepseek-chat
AI_GENERATION_MAX_OUTPUT_TOKENS=8000

# Cloudflare R2
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ACCESS_KEY_ID=
CLOUDFLARE_SECRET_ACCESS_KEY=
BUCKET_NAME=prod

# Puppeteer/Chrome for production PDF generation
PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable

# Payments
WEBHOOK_SECRET=
STATIC_PAYMENT_LINK=https://checkout.dodopayments.com/buy/PRODUCT_ID?quantity=1&redirect_url=https://noteformula.com/settings&email=USER_EMAIL&disableEmail=true
ADMIN_KEY=

# Analytics
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
