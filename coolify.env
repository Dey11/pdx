NODE_ENV=production
WEB_PORT=3000
POSTGRES_DB=pdx
POSTGRES_USER=pdx
POSTGRES_PASSWORD=replace-with-a-strong-db-password
DATABASE_URL=postgresql://pdx:replace-with-a-strong-db-password@postgres:5432/pdx?schema=public
REDIS_PASSWORD=replace-with-a-strong-redis-password
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TLS=false
BETTER_AUTH_URL=https://your-coolify-domain.com
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_TRUST_HOST=true
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM="PDX <support@your-domain.com>"
BACKEND_URL=http://web:3000
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
AI_GENERATION_MODELS=deepseek:deepseek-v4-flash,deepseek:deepseek-chat,google:gemini-2.5-flash
AI_GENERATION_MAX_OUTPUT_TOKENS=8000
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ACCESS_KEY_ID=
CLOUDFLARE_SECRET_ACCESS_KEY=
CLOUDFLARE_TOKEN_VALUE=
BUCKET_NAME=prod
PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
DODO_PAYMENTS_API_KEY=
WEBHOOK_SECRET=
STATIC_PAYMENT_LINK=
ADMIN_KEY=
