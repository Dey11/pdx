    "docker:up": "docker compose --env-file .env.production.docker up --build",
    "docker:down": "docker compose --env-file .env.production.docker down",
    "worker:dev": "bun worker/src/index.ts",
    "worker:build": "tsc -p worker/tsconfig.json",
    "worker:start": "bun worker/dist/index.js"
  },
  "packageManager": "bun@1.3.4",
